# ============================================
# TFP Asset Damage Collector - Configuration
# ============================================

# Scheduling Configuration
# Cron expression for job execution (default: 18:00 daily)
# Format: minute hour day month weekday
# Examples:
#   0 18 * * *    = Every day at 18:00
#   */30 * * * *  = Every 30 minutes
#   0 8,18 * * *  = Every day at 8:00 and 18:00
#CRON_SCHEDULE=* * * * *

# Timezone for scheduler (important for cron execution)
TZ=Europe/Rome

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=valkey-service
REDIS_PORT=6379
REDIS_STREAM_KEY=trailer-damage-stream

# ============================================
# BERLink API Configuration
# ============================================
TRAILER_API_URL=http://berlink-backend:8080
TRAILER_API_KEY=tfp-test-key-2025-DO-NOT-USE-IN-PRODUCTION
TRAILER_API_TIMEOUT=30000

# ============================================
# TFP API Configuration
# ============================================
# Base URL for TFP API (without trailing slash)
#TPF_API_URL=http://172.28.234.122:7000/api

TPF_API_URL=https://tfp.circletouch.eu/api
TPF_API_TIMEOUT=30000
TPF_API_RETRY_ATTEMPTS=3
TPF_API_USERNAME=admin.b
TPF_API_PASSWORD=TB_adm_2026.

# ============================================
# Logging Configuration
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=debug